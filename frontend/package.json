{
  "name" : "vempain-website",
  "private" : true,
  "version" : "0.0.0",
  "type" : "module",
  "engines" : {
    "node" : ">=18.0.0",
    "yarn" : ">=4.0.0"
  },
  "packageManager" : "yarn@4.13.0",
  "scripts" : {
    "prebuild" : "node generateBuildInfo.js",
    "start" : "env-cmd -f .env.local vite",
    "build" : "yarn prebuild && tsc && env-cmd -f .env.prod vite build",
    "lint" : "eslint .",
    "typecheck" : "tsc --noEmit",
    "test" : "jest --passWithNoTests",
    "test:watch" : "jest --watch",
    "test:coverage" : "jest --coverage . --passWithNoTests",
    "preview" : "vite preview",
    "build:production" : "yarn prebuild && env-cmd -f .env.prod vite build"
  },
  "dependencies" : {
    "@ant-design/icons" : "^6.1.1",
    "@vempain/vempain-auth-frontend" : "^1.0.4",
    "antd" : "^6.3.5",
    "axios" : "^1.14.0",
    "corepack" : "^0.34.6",
    "dayjs" : "^1.11.20",
    "env-cmd" : "^11.0.0",
    "leaflet" : "^1.9.4",
    "react" : "^19.2.4",
    "react-dom" : "^19.2.4",
    "react-leaflet" : "^5.0.0",
    "react-player" : "^3.4.0",
    "react-router-dom" : "^7.13.2"
  },
  "devDependencies" : {
    "@eslint/js" : "^10.0.1",
    "@types/jest" : "^30.0.0",
    "@types/leaflet" : "^1.9.21",
    "@types/node" : "^25.5.0",
    "@types/react" : "^19.2.14",
    "@types/react-dom" : "^19.2.3",
    "@vitejs/plugin-react" : "^6.0.1",
    "eslint" : "^10.1.0",
    "eslint-plugin-react-hooks" : "^7.0.1",
    "eslint-plugin-react-refresh" : "^0.5.2",
    "globals" : "^17.4.0",
    "jest" : "^30.3.0",
    "jest-environment-jsdom" : "^30.3.0",
    "ts-jest" : "^29.4.6",
    "typescript" : "^6.0.2",
    "typescript-eslint" : "^8.58.0",
    "vite" : "^8.0.3"
  },
  "jest" : {
    "preset" : "ts-jest/presets/js-with-ts",
    "testEnvironment" : "jest-environment-jsdom",
    "moduleNameMapper" : {
      "\\\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$" : "<rootDir>/__mocks__/fileMock.js",
      "\\\\.(css|less)$" : "<rootDir>/__mocks__/styleMock.js"
    },
    "transform" : {
      "^.+\\.tsx?$" : [
        "ts-jest",
        {
          "tsconfig" : "tsconfig.test.json"
        }
      ]
    }
  }
}
